# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.herokuapp.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_SECURE_SSL_REDIRECT=False

# Database
# For Heroku this is auto-provided when you attach Heroku Postgres.
# DATABASE_URL=postgres://<user>:<pass>@<host>:5432/<db_name>

# Email
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@aerokodex.com

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cloudflare R2 (optional media/file storage)
# Keep this False for local filesystem storage.
USE_CLOUDFLARE_R2=False
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# R2_REGION=auto
# Optional public bucket/custom domain URL used to build media links:
# R2_PUBLIC_URL=https://pub-<id>.r2.dev
# Set True only if you need signed URLs for private objects.
# R2_QUERYSTRING_AUTH=False
