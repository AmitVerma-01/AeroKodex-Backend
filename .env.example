# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — defaults match docker-compose.yml (postgres:16-alpine)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=aerokodex
DB_USER=aerokodex_user
DB_PASSWORD=aerokodex_secret
DB_HOST=localhost
DB_PORT=5432

